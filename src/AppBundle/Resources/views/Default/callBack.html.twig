{% extends "AppBundle::layout.html.twig" %}

{% block javascripts %}
    <script src="{{ asset('bower_components/jquery-validation/lib/jquery.js') }}" type="text/javascript"></script>
    <script src="{{ asset('bower_components/jquery-validation/jquery.validate.min.js') }}" type="text/javascript"></script>
    <script src="{{ asset('bundles/app/js/script.js') }}" type="text/javascript"></script>
{% endblock %}


{% block container %}

<div class="container">
    <div class="row">
        <div class="col-sm-6 col-sm-offset-3">
            <div class="form-top">
                <div class="form-top-left">
                    <h3>Send Message</h3>
                </div>
            </div>

            <div>
                <form id="messageForm" action="#" method="post" novalidate>


                    <div class="form-group">
                        <label class="sr-only" for="name">Name</label>
                        <input type="text" name="name" placeholder="Name..."
                               class="form-control" id="name">
                    </div>
                    <div class="form-group">
                        <label class="sr-only" for="email">Password</label>
                        <input type="email" name="email" placeholder="Email ..."
                               class="form-control" id="email" >
                    </div>

                    <div class="form-group">
                        <label class="sr-only" for="message">Message</label>
                        <textarea  name="message" placeholder="Message ..."
                               class="form-control" id="message"></textarea>
                    </div>

                    {#{% if error %}#}
                        {#<div class="form-group text-center text-danger">#}
                            {#{{ error|trans({}, 'FOSUserBundle') }}#}
                        {#</div>#}
                    {#{% endif %}#}

                    <button id="_submit" type="submit" class="btn">Sign in!</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
